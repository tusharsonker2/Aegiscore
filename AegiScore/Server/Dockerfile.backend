FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y gcc libpq-dev && rm -rf /var/lib/apt/lists/*

# Install python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
# Install extra packages needed for the new features (which might not be in original requirements)
RUN pip install --no-cache-dir scikit-learn pandas flask-jwt-extended psycopg2-binary redis gunicorn apscheduler llama-index llama-index-llms-gemini llama-index-embeddings-huggingface

COPY . .

# Run the Flask server via Gunicorn with Eventlet for Socket.io
CMD ["gunicorn", "--worker-class", "eventlet", "-w", "1", "-b", "0.0.0.0:5000", "app:app"]
